
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <https://www.w3.org/TR/skos-reference/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xs: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix FMC: <http://fmc-modeling.org#> .
@prefix casShapes_FMC: <https://product-information-graph.org/v0.2/ontology/shapes/FMC#> .
@prefix ReqIF: <https://www.prostep.org/fileadmin/downloads/PSI_ImplementationGuide_ReqIF_V1-7.pdf#> .
@prefix casShapes_ReqIF: <https://product-information-graph.org/v0.2/ontology/shapes/ReqIF#> .
@prefix cas: <https://product-information-graph.org/v0.2/metamodel#> .
@prefix casShapes_cas: <https://product-information-graph.org/v0.2/ontology/shapes/cas#> .
@prefix SpecIF: <https://specif.de/v1.2/schema#> .
@prefix casShapes_SpecIF: <https://product-information-graph.org/v0.2/ontology/shapes/SpecIF#> .

@prefix o: <https://product-information-graph.org/v0.2/ontology#> .
@prefix d: <https://product-information-graph.org/examples/Libraries%20(Example).specif#> .

#################################################################
# Project Metadata
#################################################################

d:
	rdf:type owl:Ontology ;
	rdfs:label "Libraries (Example)" ;
	rdfs:comment "An ontology-based data-set with libraries, their books and authors."@en ;
	owl:imports <http://www.w3.org/1999/02/22-rdf-syntax-ns#> ,
		<http://www.w3.org/2000/01/rdf-schema#> ;
	dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
	dcterms:modified "2026-03-25T14:27:25.758Z" .

#################################################################
# CASCaRA Metamodel
#################################################################

cas:Entity
	rdf:type owl:Class ;
	rdfs:label "Entity" ;
	skos:definition "A CASCaRA meta-model item used for entities (aka resources or artifacts)." .

casShapes_cas:Entity
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Entity ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category ,
		casShapes_cas:Icon .

cas:Package
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Package" ;
	skos:definition "A CASCaRA meta-model item used for packages comprising entities, relationships and potentially nested packages." .

casShapes_cas:Package
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Package ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:Artifact
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Artifact" ;
	skos:definition "The most generic class for all model entities (e.g. requirement, function, system, component, state, event, ...)." .

casShapes_cas:Artifact
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Artifact ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

FMC:Actor
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Artifact ;
	rdfs:label "Actor" ;
	skos:definition "A fundamental model-element class for actors (e.g. users, functions, systems, components, ...)." .

casShapes_FMC:Actor
	rdf:type sh:NodeShape ;
	sh:targetClass FMC:Actor ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

FMC:State
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Artifact ;
	rdfs:label "State" ;
	skos:definition "A fundamental model-element class for states (e.g. system or process states, information, form, color, ...)." .

casShapes_FMC:State
	rdf:type sh:NodeShape ;
	sh:targetClass FMC:State ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

FMC:Event
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Artifact ;
	rdfs:label "Event" ;
	skos:definition "A fundamental model-element class for events (e.g. environmental or process events, ...)." .

casShapes_FMC:Event
	rdf:type sh:NodeShape ;
	sh:targetClass FMC:Event ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:Organizer
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Organizer" ;
	skos:definition "A class for organizing model-elements. An example is a list of requirements or a diagram using a certain notation." .

casShapes_cas:Organizer
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Organizer ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:Root
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Root" ;
	skos:definition "A subclass of cas:Organizer serving as a root for trees and tables." .

casShapes_cas:Root
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Root ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:lists .

cas:Tree
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Tree" ;
	skos:definition "A subclass of cas:Organizer for strictly hierarchical data structures referencing entities and relationships." .

casShapes_cas:Tree
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Tree ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:lists .

cas:Outline
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Tree ;
	rdfs:label "Outline" ;
	skos:definition "A subclass of cas:Tree comprising all information items of a human-readable document. As usual, the outline is hierarchically organized." .

casShapes_cas:Outline
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Outline ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:View
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "View" ;
	skos:definition "A subclass of cas:Organizer representing a model view (diagram) using a certain notation showing selected model elements." .

casShapes_cas:View
	rdf:type sh:NodeShape ;
	sh:targetClass cas:View ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Diagram ,
		casShapes_cas:Notation ,
		casShapes_cas:shows ,
		casShapes_cas:depicts .

cas:Table
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Table" ;
	skos:definition "A subclass of cas:Organizer representing a table showing selected model elements." .

casShapes_cas:Table
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Table ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:shows .

cas:Enumeration
	rdf:type owl:Class ;
	rdfs:label "Enumeration" ;
	skos:definition "A CASCaRA meta-model item used for enumerations of values." .

casShapes_cas:Enumeration
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Enumeration ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:Relationship
	rdf:type owl:Class ;
	rdfs:label "Relationship" ;
	skos:definition "A CASCaRA meta-model item used for reified relationships (aka predicates)." .

casShapes_cas:Relationship
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Relationship ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category ,
		casShapes_cas:Icon ,
		casShapes_cas:SourceLink ,
		casShapes_cas:TargetLink .

cas:Property
	rdf:type owl:DatatypeProperty ;
	rdfs:label "Property" ;
	skos:definition "A CASCaRA meta-model item used for properties (aka attributes)." .

casShapes_cas:Property
	rdf:type sh:PropertyShape ;
	sh:path cas:Property ;
	sh:datatype xs:anyType .

cas:Icon
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "has icon" ;
	skos:definition "Specifies an icon for a model element (entity or relationship)." .

casShapes_cas:Icon
	rdf:type sh:PropertyShape ;
	sh:path cas:Icon ;
	sh:datatype xs:string ;
	sh:minCount "0" ;
	sh:maxCount "1" .

cas:Diagram
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "Diagram" ;
	skos:definition "A diagram illustrating the resource or a link to a diagram." .

casShapes_cas:Diagram
	rdf:type sh:PropertyShape ;
	sh:path cas:Diagram ;
	sh:datatype xs:string ;
	sh:minCount "0" .

cas:Category
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "has category" ;
	skos:definition "Specifies a category for an element (entity, relationship or organizer)." .

casShapes_cas:Category
	rdf:type sh:PropertyShape ;
	sh:path cas:Category ;
	sh:datatype xs:string ;
	sh:maxLength "32" ;
	sh:minCount "0" ;
	sh:maxCount "1" .

cas:Notation
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Category ;
	rdfs:label "Notation" ;
	skos:definition "A reference to a notation defining the syntax and semantics of a diagram." .

casShapes_cas:Notation
	rdf:type sh:PropertyShape ;
	sh:path cas:Notation ;
	sh:datatype xs:string ;
	sh:minCount "0" ;
	sh:maxCount "1" .

cas:Link
	rdf:type owl:ObjectProperty ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "linked with" ;
	skos:definition "A PIG meta-model item connecting a reified relationship with its source or target. Also connects an organizer to a model element." .

casShapes_cas:Link
	rdf:type sh:PropertyShape ;
	sh:path cas:Link ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:SourceLink
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:Link ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "to source" ;
	skos:definition "Connects the source of a reified relationship." .

casShapes_cas:SourceLink
	rdf:type sh:PropertyShape ;
	sh:path cas:SourceLink ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:TargetLink
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:Link ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "to target" ;
	skos:definition "Connects the target of a reified relationship or an organizer." .

casShapes_cas:TargetLink
	rdf:type sh:PropertyShape ;
	sh:path cas:TargetLink ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:lists
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
			cas:Organizer
		)] ;
	rdfs:label "lists" ;
	skos:definition "Lists an entity, a relationship or a subordinated organizer." .

casShapes_cas:lists
	rdf:type sh:PropertyShape ;
	sh:path cas:lists ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
			[ sh:class cas:Organizer ]
		) .

cas:shows
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "shows" ;
	skos:definition "Shows an entity or a relationship." .

casShapes_cas:shows
	rdf:type sh:PropertyShape ;
	sh:path cas:shows ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:depicts
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:range cas:Entity ;
	rdfs:label "depicts" ;
	skos:definition "Depicts an entity; inverse of uml:ownedDiagram." .

casShapes_cas:depicts
	rdf:type sh:PropertyShape ;
	sh:path cas:depicts ;
	sh:or (
			[ sh:class cas:Entity ]
		) .

#################################################################
# Ontology - Property Classes
#################################################################

# Skipping implicit property: rdfs:label

# Skipping implicit property: rdfs:comment

o:PC-ExlibLocation
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "exlib:Location" ;
	skos:definition "The geographic location." .

o:PC-ExlibLocation_shape
	rdf:type sh:PropertyShape ;
	sh:path o:PC-ExlibLocation ;
	sh:maxCount "1" ;
	sh:datatype xs:string ;
	sh:maxLength "256" .

o:PC-ExlibIsbn
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "exlib:ISBN" ;
	skos:definition "The International Standard Book Number (ISBN) is a numeric commercial book identifier that is intended to be unique. Publishers purchase or receive ISBNs from an affiliate of the International ISBN Agency. <small><i>Source: [Wikipedia](https://en.wikipedia.org/wiki/ISBN)</i></small>" .

o:PC-ExlibIsbn_shape
	rdf:type sh:PropertyShape ;
	sh:path o:PC-ExlibIsbn ;
	sh:minCount "1" ;
	sh:maxCount "1" ;
	sh:datatype xs:string ;
	sh:maxLength "32" .

# Skipping implicit property: cas:Diagram

# Skipping implicit property: cas:Category

#################################################################
# Ontology - Entity Classes
#################################################################

o:RC-ExlibLibrary
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "exlib:Library" ;
	skos:definition "Term used for libraries in the example." ;
	cas:Icon "&#8962;" .

o:RC-ExlibLibrary_shape
	rdf:type sh:NodeShape ;
	sh:targetClass o:RC-ExlibLibrary ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		o:PC-ExlibLocation_shape .

o:RC-ExlibBook
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "exlib:Book" ;
	skos:definition "In the example, the term used for books. Editions are represented, not the individuals." ;
	cas:Icon "&#128463;" .

o:RC-ExlibBook_shape
	rdf:type sh:NodeShape ;
	sh:targetClass o:RC-ExlibBook ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		o:PC-ExlibIsbn_shape .

o:RC-ExlibAuthor
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "exlib:Author" ;
	skos:definition "Term used for book authors in the example." ;
	cas:Icon "&#9998;" .

o:RC-ExlibAuthor_shape
	rdf:type sh:NodeShape ;
	sh:targetClass o:RC-ExlibAuthor ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

SpecIF:Paragraph
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Paragraph"@en ,
		"Textabsatz"@de ,
		"Paragraphe"@fr ;
	skos:definition "<p>A 'Paragraph' is an unspecified information in a document at any level.</p>"@en ,
		"<p>Ein 'Textabschnitt' in einem Dokument auf beliebiger Ebene.</p>"@de .

casShapes_SpecIF:Paragraph
	rdf:type sh:NodeShape ;
	sh:targetClass SpecIF:Paragraph ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Diagram ,
		casShapes_cas:Category .

#################################################################
# Ontology - Relationship Classes
#################################################################

o:SC-ExlibOwnedby
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Relationship ;
	rdfs:label "exlib:owned-by" ;
	skos:definition "A relation to express that a book is owned by a library." ;
	dcterms:modified "2025-07-09T13:17:31.049Z" .

o:SC-ExlibOwnedby-toSource
	rdfs:subPropertyOf cas:SourceLink ;
	rdfs:label "o:SC-ExlibOwnedby to source" ;
	rdfs:comment "Connects the source of o:SC-ExlibOwnedby" ;
	rdfs:domain o:SC-ExlibOwnedby ;
	rdfs:range o:RC-ExlibBook .

o:SC-ExlibOwnedby-toTarget
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:label "o:SC-ExlibOwnedby to target" ;
	rdfs:comment "Connects the target of o:SC-ExlibOwnedby" ;
	rdfs:domain o:SC-ExlibOwnedby ;
	rdfs:range o:RC-ExlibLibrary .

o:SC-ExlibOwnedby_shape
	rdf:type sh:NodeShape ;
	sh:targetClass o:SC-ExlibOwnedby ;
	sh:property [ 
		sh:path o:SC-ExlibOwnedby-toSource ;
		sh:or (
			[ sh:class o:RC-ExlibBook ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] ;
	sh:property [ 
		sh:path o:SC-ExlibOwnedby-toTarget ;
		sh:or (
			[ sh:class o:RC-ExlibLibrary ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

o:SC-ExlibWrittenby
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Relationship ;
	rdfs:label "exlib:written-by" ;
	skos:definition "A relation to express that a book is written by an author." ;
	dcterms:modified "2025-07-09T13:18:11.433Z" .

o:SC-ExlibWrittenby-toSource
	rdfs:subPropertyOf cas:SourceLink ;
	rdfs:label "o:SC-ExlibWrittenby to source" ;
	rdfs:comment "Connects the source of o:SC-ExlibWrittenby" ;
	rdfs:domain o:SC-ExlibWrittenby ;
	rdfs:range o:RC-ExlibBook .

o:SC-ExlibWrittenby-toTarget
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:label "o:SC-ExlibWrittenby to target" ;
	rdfs:comment "Connects the target of o:SC-ExlibWrittenby" ;
	rdfs:domain o:SC-ExlibWrittenby ;
	rdfs:range o:RC-ExlibAuthor .

o:SC-ExlibWrittenby_shape
	rdf:type sh:NodeShape ;
	sh:targetClass o:SC-ExlibWrittenby ;
	sh:property [ 
		sh:path o:SC-ExlibWrittenby-toSource ;
		sh:or (
			[ sh:class o:RC-ExlibBook ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] ;
	sh:property [ 
		sh:path o:SC-ExlibWrittenby-toTarget ;
		sh:or (
			[ sh:class o:RC-ExlibAuthor ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

